# Copy to .env and fill in real values

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://tripenforce:tripenforce@localhost:5432/tripenforce

# Anthropic — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Duffel sandbox — get from https://app.duffel.com/join
DUFFEL_API_KEY=duffel_test_...

# Amadeus (optional second provider, decommissions July 17 2026) — https://developers.amadeus.com
# Sign up → My Apps → Create new app → copy API Key and API Secret
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Optional
DEBUG=false
LOG_LEVEL=INFO
CLAUDE_MODEL=claude-sonnet-4-20250514
